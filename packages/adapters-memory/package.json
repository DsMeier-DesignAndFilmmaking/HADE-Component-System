{
  "name": "@hade/adapters-memory",
  "version": "0.1.0-alpha.0",
  "private": false,
  "description": "In-process LRU CacheAdapter for HADE (dev/CI/single-instance).",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "peerDependencies": {
    "@hade/core": "*"
  },
  "devDependencies": {
    "@hade/core": "workspace:*",
    "typescript": "^5.8.2"
  }
}
