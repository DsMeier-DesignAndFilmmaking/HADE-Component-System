# HADE Backend — Environment Variables
# Copy to .env and fill in values before starting the server.

# ─── LLM Provider Configuration ──────────────────────────────────────────────
# Which LLM provider to use: "anthropic" | "openai" | "google"
HADE_LLM_PROVIDER=anthropic

# Anthropic API key (required if HADE_LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_key_here
# HADE_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI API key (required if HADE_LLM_PROVIDER=openai)
OPENAI_API_KEY=your_key_here
# HADE_OPENAI_MODEL=gpt-4o-mini

# Google API key — used for both Google AI (Gemini) and Google Places venue search.
# Required if HADE_LLM_PROVIDER=google OR venue search is enabled.
GOOGLE_API_KEY=your_google_api_key_here
# HADE_GOOGLE_MODEL=gemini-1.5-flash

# LLM request timeout in seconds — fallback triggers if exceeded (default: 5.0, max recommended: 6.0)
# HADE_LLM_TIMEOUT=5.0

# ─── Server ──────────────────────────────────────────────────────────────────
# Port (optional — defaults to 8000)
# PORT=8000
