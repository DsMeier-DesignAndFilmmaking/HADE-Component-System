{
  "name": "hade-system-v1",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm run sdk:build && pnpm --filter demo build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc -b",
    "demo:ci": "pnpm run sdk:build && pnpm --filter demo type-check && pnpm --filter demo lint && pnpm --filter demo build && pnpm --filter demo test",
    "sync": "node --env-file=.env scripts/sync-notion.js",
    "sdk:build": "pnpm -r --filter \"@hade/*\" run build",
    "sdk:type-check": "pnpm -r --filter \"@hade/*\" run type-check",
    "sdk:check:cycles": "madge --circular --extensions ts,tsx packages/",
    "sdk:check:budgets": "node scripts/check-bundle-budgets.mjs",
    "sdk:check:boundaries": "eslint --config eslint.sdk.config.mjs packages/",
    "sdk:audit:core-purity": "node scripts/audit-core-purity.mjs",
    "sdk:audit:package-purity": "node scripts/audit-package-purity.mjs",
    "sdk:pack:dry-run": "node scripts/pack-dry-run.mjs",
    "pack:dry-run": "pnpm run sdk:pack:dry-run",
    "sdk:ci": "pnpm run sdk:type-check && pnpm run sdk:audit:core-purity && pnpm run sdk:audit:package-purity && pnpm run sdk:check:cycles && pnpm run sdk:check:boundaries && pnpm run sdk:build && pnpm run sdk:check:budgets",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm run sdk:build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@notionhq/client": "^2.2.15",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.31.0",
    "madge": "^8.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.2",
    "vitest": "^4.1.4"
  }
}
