# Public (safe in browser)
# Optional override. Leave unset to use same-origin /api (recommended for Vercel).
# NEXT_PUBLIC_HADE_API_BASE=https://your-domain.example.com/api

# Optional: enables the "Pin exact spot" step in UGC creation.
# Must be a Mapbox **public** token (pk.…) — NEVER a secret (sk.…) token.
# Restrict it via the Mapbox dashboard before deploying:
#   • Scopes: styles:read, fonts:read, tiles:read
#   • URL referrer allowlist: your production hostname + localhost:* for dev
# A leaked public token rotates safely; referrer restriction is the security boundary.
# If unset, the four other location modes still work — the Pin button is hidden.
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_public_token_here

# Private (server-side only)
HADE_API_KEY=your_secret_here
OPENAI_API_KEY=your_openai_key_here

# Optional: upstream HADE engine used by /api/hade/decide proxy.
# Leave unset in Vercel to skip Tier 1 and rely on Tier 2 (Google Places).
HADE_UPSTREAM_URL=http://localhost:8000

# Required for Tier 2 (synthetic decisions from real venue candidates).
GOOGLE_API_KEY=

# ── Upstash Redis (REQUIRED in production) ────────────────────────────────────
# Without these the app will throw on startup in production.
# In development, an in-memory fallback is used with a console warning.
# Get credentials at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
